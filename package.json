{
  "name": "google-service",
  "version": "1.0.0",
  "description": "Google Ads API wrapper service for MCC agency management",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outdir=dist --format=cjs --packages=external",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate-openapi": "tsx src/generate-openapi.ts",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "google-ads-api": "^23.0.0",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0",
    "vitest": "^2.1.0"
  }
}

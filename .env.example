PORT=8080
GOOGLE_SERVICE_DATABASE_URL=postgresql://user:password@host:5432/google_service
GOOGLE_SERVICE_API_KEY=your-google-service-api-key
KEY_SERVICE_URL=https://key.mcpfactory.org
KEY_SERVICE_API_KEY=your-key-service-api-key
RUNS_SERVICE_URL=https://runs.mcpfactory.org
RUNS_SERVICE_API_KEY=your-runs-service-api-key
BILLING_SERVICE_URL=https://billing.mcpfactory.org
BILLING_SERVICE_API_KEY=your-billing-service-api-key

# Google CRM (Gmail + People bronze ingestion)
# Read ONLY in src/instrumentation.ts at cold start (registered as platform keys via key-service).
# Never read in business logic — use getGoogleOAuthClient() from services/key-service.ts instead.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Read at runtime in business logic (not a secret)
GOOGLE_OAUTH_REDIRECT_URI=https://google.mcpfactory.org/orgs/google/auth/callback
GOOGLE_GMAIL_BACKFILL_DAYS=365
